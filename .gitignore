# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Generated outputs / debug
outputs/
debug_outputs/

# Environment / secrets
.env

# Python virtualenv (use conda base /opt/miniconda3 instead)
.venv/

# ---------------------------------------------------------------------------
# Raw images — NOT pushed (re-download locally).
# Training annotations + YOLO exports ARE tracked (see below).
# ---------------------------------------------------------------------------
labeling/data/
labeling/dataset/
smoothie_dataset/

# SQLite WAL/SHM + local DB backups (labels.db itself IS tracked)
labeling/labels.db-*
labeling/labels.db.bak*
/labels.db

# Train-time absolute-path yaml written by training/train_multi.py
labeling/**/_train_data.yaml

# Superseded checkpoint backups
checkpoints/*.bak*

# ---------------------------------------------------------------------------
# Weights: ignore .pt by default, then allow YOLO deploy + training runs.
# Base yolo11n-seg.pt auto-downloads via ultralytics.
# ---------------------------------------------------------------------------
*.pt
!checkpoints/yolo_*.pt
!runs/**/weights/*.pt

# Ignore training-run artifacts other than weights/
runs/**
!runs/**/
!runs/**/weights/
!runs/**/weights/**
