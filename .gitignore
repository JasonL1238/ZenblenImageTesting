# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Generated outputs
active_pipeline/outputs/
training/outputs/
training/labeling/data/
training/labeling/dataset/

# Experimentation: keep the code, drop heavy generated outputs (mask cache,
# comparison panels, validation dumps) — never needed on a training box.
experimentation/**/outputs/

# Environment / secrets
.env
.venv/

# SQLite WAL/SHM + local DB backups (labels.db itself IS tracked)
training/labeling/labels.db-*
training/labeling/labels.db.bak*

# Train-time absolute-path yaml
training/labeling/**/_train_data.yaml

# Weights: ignore .pt by default, then allow deploy + training checkpoints/runs
*.pt
!active_pipeline/checkpoints/yolo_*.pt
!training/checkpoints/yolo_*.pt
!active_pipeline/checkpoints/best_cleaning.pt
!training/checkpoints/best_cleaning.pt
!training/runs/**/weights/*.pt

# Training-run artifacts other than weights/
training/runs/**
!training/runs/**/
!training/runs/**/weights/
!training/runs/**/weights/**
