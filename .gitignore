# SAM checkpoints (download separately — see CLAUDE.md)
checkpoints/*.pt

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Generated outputs
outputs/

# Environment / secrets
.env

# Labeling tool artefacts (downloaded images, SAM caches, verdicts, dataset)
labeling/data/
labeling/dataset/
labeling/labels.db
labeling/labels.db-*
# Local safety snapshots — kept on disk, never committed
labeling/labels.db.bak*
# Stray root DB created by running a script from the repo root
/labels.db

# Superseded weight backups (originals preserved in runs/<mode>-seg/*/weights/best.pt)
checkpoints/*.bak*

# Multi-mode labeler (app_multi.py) per-mode exports — code committed, data not.
labeling/spill_dataset/
labeling/logo_dataset/
labeling/smoothie_dataset_std/

# Dataset pipeline output (master annotations, generated masks, exports) — the
# CODE that builds these is committed; the generated data is not.
smoothie_dataset/
debug_outputs/

# Python virtualenv (use conda base /opt/miniconda3 instead)
.venv/

# YOLO base checkpoint (download before training)
yolo11n-seg.pt
*.pt

# Training run outputs (weights, logs, plots)
runs/
